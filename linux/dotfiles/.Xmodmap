! configure order: remove-> assign -> add


! ### remove assignments
! remove caps assignment from lock
remove lock = Caps_Lock


! ### assign keys
! NOTE: keycode X = <unmodified> <Shift+Key> <Mode_switch(AltGr)+Key> <Shift+Mode_switch+Key>

! swap ctrl and caps
keycode 66 = Control_L
keycode 37 = Caps_Lock NoSymbol Caps_Lock

! muhenkan as alt
keycode 102 = Alt_L Meta_L Alt_L Meta_L

! henkan as enter, shift + henkan as backspace
keycode 100 = Return Return Return Return

! kana as escape
! old: keycode 101 = BackSpace BackSpace BackSpace BackSpace
keycode 101 = Escape Escape Escape Escape


! ### add keys
! assign ctrl as control keymodifier
add control = Control_L

